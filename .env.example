# CricketStudio OKF — local env vars
# Copy to .env or .env.local and fill in your keys.
# Note: the benchmark runner lives in the private cricketstudio monorepo.
# These vars are kept here for reference; set them as GitHub Actions secrets in that repo.

# Required: used as Claude Sonnet model + Claude Haiku judge
ANTHROPIC_API_KEY=sk-ant-...

# Optional: missing keys skip that model in the benchmark
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...
