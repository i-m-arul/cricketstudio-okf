# CricketStudio OKF — local env vars
# Copy to .env or .env.local and fill in your keys.
# These are loaded automatically by scripts/run-benchmark.mjs.
# In GitHub Actions, set these as repository secrets instead.

# Required: used as Claude Sonnet model + Claude Haiku judge
ANTHROPIC_API_KEY=sk-ant-...

# Optional: missing keys skip that model in the benchmark
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...

# Optional: override cost cap (default $50 per run)
# BENCHMARK_COST_CAP=50
