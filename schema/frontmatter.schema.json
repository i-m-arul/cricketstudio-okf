{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://okf.cricketstudio.ai/schema/frontmatter.schema.json",
  "title": "CricketStudio OKF Frontmatter",
  "description": "Schema for the YAML frontmatter block of every CricketStudio OKF markdown file. Authoritative field set per CLAUDE.md \u00c2\u00a77; fields from REQUIREMENTS.md \u00c2\u00a714 are accepted as documented aliases.",
  "type": "object",
  "required": [
    "type",
    "title",
    "description",
    "status",
    "last_verified",
    "license",
    "source_system",
    "source_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "description": "The concept type. One of the 15 approved values (REQUIREMENTS.md \u00c2\u00a714.3).",
      "type": "string",
      "enum": [
        "index",
        "player",
        "team",
        "league",
        "season",
        "match",
        "venue",
        "metric",
        "methodology",
        "source",
        "dossier",
        "runbook",
        "reference",
        "claim",
        "api",
        "research",
        "record",
        "leaderboard"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "description": "Lifecycle state of the document.",
      "type": "string",
      "enum": [
        "active",
        "draft",
        "deprecated",
        "archived"
      ]
    },
    "last_verified": {
      "description": "ISO-8601 date the content was last verified against source.",
      "type": "string",
      "format": "date"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "source_boundary": {
      "description": "Licensing/redistribution boundary for the data this file relies on (REQUIREMENTS.md \u00c2\u00a721.3).",
      "type": "string",
      "enum": [
        "derived_claims_only",
        "public_open_data",
        "proprietary_source_not_redistributed",
        "manual_curated_knowledge",
        "methodology_only"
      ]
    },
    "resource": {
      "description": "Best canonical CricketStudio page or API resource. Required for concept-bearing types.",
      "type": "string",
      "format": "uri"
    },
    "canonical_page": {
      "type": "string",
      "format": "uri"
    },
    "api_resource": {
      "type": "string",
      "format": "uri"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "entity_id": {
      "description": "Stable entity id, e.g. cricketstudio:player:virat-kohli.",
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "description": "Relative paths to related OKF files (forms the concept graph).",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "description": "Provenance block. Required for files that carry data-dependent claims.",
      "type": "object",
      "required": [
        "source",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "notes": {
          "type": "string"
        },
        "computed_at": {
          "type": "string",
          "description": "ISO-8601 timestamp the underlying claim was computed (from snapshot)."
        },
        "snapshot": {
          "type": "string"
        }
      }
    },
    "dataset_version": {
      "description": "Snapshot date/version the data was drawn from.",
      "type": "string"
    },
    "review_required": {
      "description": "When true, the file is flagged as not release-ready.",
      "type": "boolean"
    },
    "generated": {
      "description": "Reserved for v0.2: marks a file emitted by scripts/generate_okf.py vs. hand-curated.",
      "type": "boolean"
    },
    "timestamp": {
      "description": "Alias of last_verified accepted from REQUIREMENTS.md \u00c2\u00a714.1.",
      "type": "string",
      "format": "date"
    },
    "version": {
      "description": "Document version (REQUIREMENTS.md \u00c2\u00a714.1), e.g. 0.1.0.",
      "type": "string"
    },
    "cricketstudio_id": {
      "description": "Alias of entity_id accepted from REQUIREMENTS.md \u00c2\u00a714.2.",
      "type": "string"
    },
    "confidence": {
      "description": "Flat confidence accepted from REQUIREMENTS.md \u00c2\u00a714.2 (prefer provenance.confidence).",
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "review_status": {
      "description": "Curation status accepted from REQUIREMENTS.md \u00c2\u00a714.2.",
      "type": "string",
      "enum": [
        "curated",
        "generated",
        "draft"
      ]
    },
    "team": {
      "description": "Current or primary team for a player entity.",
      "type": "string"
    },
    "nationality": {
      "description": "Player nationality.",
      "type": "string"
    },
    "same_as": {
      "description": "External entity identifiers (Wikipedia, Wikidata, ESPNcricinfo, etc.).",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "batting_handedness": {
      "type": "string",
      "enum": [
        "right",
        "left"
      ]
    },
    "bowling_style": {
      "type": "string"
    },
    "role": {
      "description": "Player's primary role (batter, bowler, all-rounder, wicket-keeper).",
      "type": "string",
      "enum": ["batter", "bowler", "all-rounder", "wicket-keeper", "wk-batter"]
    },
    "dob": {
      "description": "Date of birth in ISO-8601 format.",
      "type": "string",
      "format": "date"
    },
    "birth_place": {
      "description": "City or region of birth.",
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "metric"
          }
        }
      },
      "then": {
        "required": [
          "resource"
        ]
      }
    }
  ]
}